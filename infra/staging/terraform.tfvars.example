# =============================================================================
# Open Pay — Staging Terraform Variables
# Copy to terraform.tfvars and fill in real values:
#   cp terraform.tfvars.example terraform.tfvars
# =============================================================================

do_token          = "dop_v1_CHANGE_ME"
ssh_key_name      = "your-ssh-key-name-in-digitalocean"
region            = "sgp1"
droplet_size      = "s-2vcpu-4gb"
postgres_password = "CHANGE_ME_staging_db_password"
app_domain        = "staging.yourdomain.com"
create_reserved_ip = false

# Restrict SSH to your IP (recommended):
# ssh_allow_cidrs = ["YOUR.IP.HERE/32"]
