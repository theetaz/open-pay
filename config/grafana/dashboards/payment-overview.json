{
  "dashboard": {
    "title": "Open Pay — Payment Overview",
    "uid": "openpay-payments",
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-24h", "to": "now" },
    "panels": [
      {
        "title": "Payments Created / min",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [{ "expr": "rate(payments_created_total[5m]) * 60" }]
      },
      {
        "title": "Payment Success Rate",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [{ "expr": "rate(payments_paid_total[1h]) / rate(payments_created_total[1h]) * 100" }],
        "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
      },
      {
        "title": "Revenue (USDT)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [{ "expr": "payments_revenue_usdt_total" }]
      },
      {
        "title": "Fees Collected (USDT)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [{ "expr": "payments_fees_usdt_total" }]
      },
      {
        "title": "Payments by Status",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          { "expr": "rate(payments_created_total[5m])", "legendFormat": "Created" },
          { "expr": "rate(payments_paid_total[5m])", "legendFormat": "Paid" },
          { "expr": "rate(payments_expired_total[5m])", "legendFormat": "Expired" },
          { "expr": "rate(payments_failed_total[5m])", "legendFormat": "Failed" }
        ]
      },
      {
        "title": "Payments by Provider",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [{ "expr": "payments_created_total", "legendFormat": "{{ provider }}" }]
      },
      {
        "title": "Payment Creation Latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
        "targets": [
          { "expr": "histogram_quantile(0.50, rate(payment_creation_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
          { "expr": "histogram_quantile(0.95, rate(payment_creation_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
          { "expr": "histogram_quantile(0.99, rate(payment_creation_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
        ]
      }
    ]
  }
}
