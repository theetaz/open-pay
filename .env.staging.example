# =============================================================================
# Open Lanka Payment — STAGING Environment Configuration
# Copy to .env.staging on the staging VPS: cp .env.staging.example .env.staging
# Branch: develop  |  VPS: staging droplet
# =============================================================================

# --- Security (min 32 chars, generate with: openssl rand -base64 32) ---
JWT_SECRET=

# --- PostgreSQL ---
POSTGRES_PASSWORD=

# --- Migration host (localhost from the VPS, port 5433 because docker maps 5433:5432) ---
MIGRATE_DB_HOST=localhost
MIGRATE_DB_PORT=5433

# --- Merchant Portal URL (used for payment redirect links) ---
MERCHANT_PORTAL_URL=https://staging-merchant.yourdomain.com

# --- MinIO / S3 Storage ---
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- SMTP (Mailpit for staging, or use Resend with staging key) ---
# Option A: Mailpit (local email testing on staging)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@staging.yourdomain.com

# Option B: Resend (real emails for staging QA)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=2587
# SMTP_USERNAME=resend
# SMTP_PASSWORD=
# SMTP_FROM=noreply@staging.yourdomain.com

# --- Logging ---
LOG_LEVEL=debug
