{
    "name": "openpay/sdk",
    "description": "Open Pay PHP SDK — crypto-to-fiat payment processing",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "OpenPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenPay\\Tests\\": "tests/"
        }
    }
}
