# =============================================================================
# Open Lanka Payment — PRODUCTION Environment Configuration
# Copy to .env.prod on the production VPS: cp .env.prod.example .env.prod
# Branch: main  |  VPS: production droplet
# =============================================================================

# --- Security (min 32 chars, generate with: openssl rand -base64 32) ---
# MUST be a strong, unique secret. Never reuse the staging secret.
JWT_SECRET=

# --- PostgreSQL ---
POSTGRES_PASSWORD=

# --- Migration host (port 5433 because docker maps 5433:5432) ---
MIGRATE_DB_HOST=localhost
MIGRATE_DB_PORT=5433

# --- Merchant Portal URL (production domain) ---
MERCHANT_PORTAL_URL=https://olp-merchant.nipuntheekshana.com

# --- MinIO / S3 Storage ---
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- SMTP (Resend — port 2587 required on DigitalOcean, 587 is blocked) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=2587
SMTP_USERNAME=resend
SMTP_PASSWORD=
SMTP_FROM=noreply@nipuntheekshana.com

# --- Logging ---
LOG_LEVEL=info
