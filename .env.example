# =============================================================================
# Open Lanka Payment — Environment Configuration
# Copy this file to .env and adjust values for your environment
# =============================================================================

# JWT Secret — MUST change in production (min 32 chars)
JWT_SECRET=dev-jwt-secret-change-in-production-min32chars

# PostgreSQL password (used by docker-compose.prod.yml)
POSTGRES_PASSWORD=olp_dev_password

# Database URLs (one per service)
MERCHANT_DATABASE_URL=postgres://olp:olp_dev_password@localhost:5433/merchant_db?sslmode=disable
PAYMENT_DATABASE_URL=postgres://olp:olp_dev_password@localhost:5433/payment_db?sslmode=disable
SETTLEMENT_DATABASE_URL=postgres://olp:olp_dev_password@localhost:5433/settlement_db?sslmode=disable
EXCHANGE_DATABASE_URL=postgres://olp:olp_dev_password@localhost:5433/exchange_db?sslmode=disable
WEBHOOK_DATABASE_URL=postgres://olp:olp_dev_password@localhost:5433/webhook_db?sslmode=disable
SUBSCRIPTION_DATABASE_URL=postgres://olp:olp_dev_password@localhost:5433/subscription_db?sslmode=disable
NOTIFICATION_DATABASE_URL=postgres://olp:olp_dev_password@localhost:5433/notification_db?sslmode=disable
ADMIN_DATABASE_URL=postgres://olp:olp_dev_password@localhost:5433/admin_db?sslmode=disable
DIRECTDEBIT_DATABASE_URL=postgres://olp:olp_dev_password@localhost:5433/directdebit_db?sslmode=disable

# Service Ports
GATEWAY_PORT=8080
PAYMENT_PORT=8081
MERCHANT_PORT=8082
SETTLEMENT_PORT=8083
WEBHOOK_PORT=8084
EXCHANGE_PORT=8085
SUBSCRIPTION_PORT=8086
NOTIFICATION_PORT=8087
ADMIN_PORT=8088
DIRECTDEBIT_PORT=8089

# Service URLs (for gateway proxy and inter-service communication)
MERCHANT_SERVICE_URL=http://localhost:8082
PAYMENT_SERVICE_URL=http://localhost:8081
EXCHANGE_SERVICE_URL=http://localhost:8085
SETTLEMENT_SERVICE_URL=http://localhost:8083
WEBHOOK_SERVICE_URL=http://localhost:8084
SUBSCRIPTION_SERVICE_URL=http://localhost:8086
NOTIFICATION_SERVICE_URL=http://localhost:8087
ADMIN_SERVICE_URL=http://localhost:8088
DIRECTDEBIT_SERVICE_URL=http://localhost:8089

# MinIO / S3 Storage
# Note: Go services read MINIO_* env vars. docker-compose.prod.yml maps S3_* → MINIO_*.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123

# SMTP — Mailpit for dev, Resend for production
# Dev (Mailpit):
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@openlankapay.dev
# Production (Resend on DigitalOcean — port 2587 required, 587 is blocked):
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=2587
# SMTP_USERNAME=resend
# SMTP_PASSWORD=re_xxxx  # your Resend API key
# SMTP_FROM=noreply@nipuntheekshana.com

# NATS
NATS_URL=nats://localhost:4222

# Redis
REDIS_URL=redis://localhost:6379

# Frontend
VITE_API_URL=http://localhost:8080

# Logging
LOG_LEVEL=info
